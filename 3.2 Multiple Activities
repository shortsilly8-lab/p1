Second_activity.java
              package com.example.welcomemessageapp;
              import android.os.Bundle;
              import android.widget.TextView;
              import androidx.appcompat.app.AppCompatActivity;
              public class SecondActivity extends AppCompatActivity {
                  TextView tvMessage;
                  @Override
                  protected void onCreate(Bundle savedInstanceState) {
                      super.onCreate(savedInstanceState);
                      setContentView(R.layout.activity_second);
                      // Link TextView
                      tvMessage = findViewById(R.id.tvMessage);
                      // Get data sent from MainActivity
                      String name = getIntent().getStringExtra("username");
                      // Display personalized message
                      tvMessage.setText("Hello, " + name + "! Welcome to the App.");
                  }
              }
              
MainActivity.java
          package com.example.welcomemessageapp;
          import android.content.Intent;
          import android.os.Bundle;
          import android.view.View;
          import android.widget.Button;
          import android.widget.EditText;
          import androidx.appcompat.app.AppCompatActivity;
          public class MainActivity extends AppCompatActivity {
              EditText etName;
              Button btnNext;
              @Override
              protected void onCreate(Bundle savedInstanceState) {
                  super.onCreate(savedInstanceState);
                  setContentView(R.layout.activity_main);
                  // Linking UI components with Java
                  etName = findViewById(R.id.etName);
                  btnNext = findViewById(R.id.btnNext);
                  // Button click event
                  btnNext.setOnClickListener(new View.OnClickListener() {
                      @Override
                      public void onClick(View view) {
                          // Get user input
                          String name = etName.getText().toString();
                          // Create Intent to move to SecondActivity
                          Intent intent = new Intent(MainActivity.this, com.example.welcomemessageapp.SecondActivity.class);
                          // Pass data using Intent
                          intent.putExtra("username", name);
                          // Start second activity
                          startActivity(intent);
                      }
                  });
              }
          }
          
